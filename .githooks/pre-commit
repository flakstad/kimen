#!/usr/bin/env bash
set -euo pipefail

# Skip locally if needed (e.g. WIP commits).
if [[ "${KIMEN_SKIP_PRECOMMIT:-}" == "1" ]]; then
  exit 0
fi

# Keep commits fast by default; run checks only when explicitly requested.
if [[ "${KIMEN_PRECOMMIT_TEST:-}" == "1" ]]; then
  make test
fi

# Opt-in full build check for explicit local verification.
if [[ "${KIMEN_PRECOMMIT_BUILD:-}" == "1" ]]; then
  make build
fi
